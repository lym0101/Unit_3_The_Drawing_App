//Color Pallette
color lightCyan = #caf0f8;
color mediumSkyBlue = #90e0ef;
color darkerBlue = #0096c7;
color darkestBlue = #03045e;
color paleYellow = #ffe6a7;
color blueHue = #a2d2ff;

float sliderY;
float radius;

void setup () {
  size(800,800);
  strokeWeight(5);
  stroke(darkestBlue);
  fill(lightCyan);
  sliderY = 400;
  radius = 0;
}
  
